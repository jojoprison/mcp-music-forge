# Core
APP_ENV=dev
TZ=Asia/Bangkok

# Redis / Queue
# Dev: redis://redis:6379/0 (docker-compose redis container)
# Prod: redis://host.docker.internal:6379/5 (host redis, db5)
REDIS_URL=redis://redis:6379/0

# Storage
STORAGE_DIR=/app/data

# Database (for admin panel and job registry)
DATABASE_URL=sqlite:////app/data/db.sqlite3

# Providers
SOUNDCLOUD_COOKIE_FILE=
ALLOW_STREAM_DOWNLOADS=true

# Transcoding
FFMPEG_BIN=ffmpeg

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# API
API_HOST=0.0.0.0
API_PORT=8033
# Bot → API URL. Prod (bot inside api): http://localhost:8033
# Dev (separate bot container): http://api:8033
API_BASE_URL=http://api:8033
